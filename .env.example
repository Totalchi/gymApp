# Supabase project credentials.
# Haal deze op in je Supabase dashboard: Project Settings -> API Keys.

# Project URL (Settings -> API -> Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Publieke key voor de browser. Nieuwe Supabase-projecten tonen een
# "publishable" key (sb_publishable_...). Oudere projecten tonen een "anon"
# key. Vul er één in -- de app accepteert beide variabelenamen.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...   # (alternatief, oude stijl)

# GEHEIME key, alleen lokaal nodig om de oefeningen te seeden (npm run seed).
# Dit is de "secret" key (sb_secret_...) of de oude "service_role" key.
# NOOIT in de browser gebruiken of committen!
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# ---------------------------------------------------------------------------
# Web Push (echte telefoonmeldingen). Genereer een sleutelpaar met:
#   npx web-push generate-vapid-keys
# Zet de publieke sleutel in NEXT_PUBLIC_VAPID_PUBLIC_KEY (browser + server)
# en de private sleutel in VAPID_PRIVATE_KEY (alleen server).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact-URL voor push-providers (mailto: of https:). Optioneel.
VAPID_SUBJECT=mailto:noreply@gymapp.app
